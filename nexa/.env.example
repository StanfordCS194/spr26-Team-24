# =============================================================================
# Nexa — Environment template
# =============================================================================
# Copy this file to .env.local and fill in real values before running `npm run
# dev`. NEVER commit .env.local. Production secrets live in Vercel — see
# VERCEL_SETUP.md.
# =============================================================================

# --- Database ---
# Local dev:  postgresql://nexa:nexa_dev_password@localhost:5433/nexa
# Production: paste the pooled connection string from Neon / Vercel Postgres
DATABASE_URL=

# --- Auth ---
# Generate with: openssl rand -base64 32
JWT_SECRET=

# --- LLM providers ---
# OpenAI is required for /api/reports/classify in production.
# Anthropic + Google are only needed on the llm-comparison branch.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Telemetry (PostHog) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
